:root {
  /* Color Palette - Deeper and more sophisticated */
  --primary: #5c7cfa; /* Brighter, premium Indigo */
  --primary-dark: #364fc7;
  --secondary: #ff922b; /* Warm orange accent */
  --accent: #20c997; /* Teal for success */
  --bg-color: #f8fafc;
  --secondary-bg: #ffffff;
  --text-dark: #1e293b;
  --text-muted: #64748b;
  --card-bg: rgba(255, 255, 255, 0.85);
  --border-color: rgba(226, 232, 240, 0.5);
  
  /* Modern Mesh Gradient Colors */
  --mesh-1: #e0e7ff;
  --mesh-2: #fae8ff;
  --mesh-3: #f1f5f9;

  /* Sizing and Spacing */
  --container-max-width: 1280px;
  --section-padding: 120px 0;
  --border-radius: 20px;
  --transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

body {
  font-family: var(--font-family);
  background-color: var(--bg-color);
  color: var(--text-dark);
  line-height: 1.6;
}

.container {
  max-width: var(--container-max-width);
  margin: 0 auto;
  padding: 0 24px;
}

/* Navbar */
.navbar {
  height: 80px;
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(10px);
  position: sticky;
  top: 0;
  z-index: 1000;
  border-bottom: 1px solid var(--border-color);
}

.navbar-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.logo {
  display: flex;
  align-items: center;
  gap: 8px;
  text-decoration: none;
  font-weight: 700;
  font-size: 1.5rem;
  color: var(--primary-dark);
}

.nav-links {
  display: flex;
  gap: 32px;
}

.nav-links a {
  text-decoration: none;
  color: var(--text-muted);
  font-weight: 500;
  font-size: 1rem;
  transition: var(--transition);
}

.nav-links a:hover {
  color: var(--primary);
}

/* Buttons */
.btn {
  padding: 12px 24px;
  border-radius: var(--border-radius);
  font-weight: 600;
  font-size: 1rem;
  cursor: pointer;
  border: none;
  transition: var(--transition);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.btn-primary {
  background-color: var(--primary);
  color: white;
}

.btn-primary:hover {
  background-color: var(--primary-dark);
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(74, 111, 165, 0.3);
}

.btn-outline {
  background-color: transparent;
  border: 2px solid var(--border-color);
  color: var(--text-dark);
}

.btn-outline:hover {
  border-color: var(--primary);
  color: var(--primary);
  background-color: rgba(74, 111, 165, 0.05);
}

.btn-lg {
  padding: 16px 36px;
  font-size: 1.125rem;
}

/* Hero Section */
.hero {
  padding: 100px 0;
  position: relative;
  overflow: hidden;
}

.hero-content {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 60px;
}

.hero-text-area .badge {
  background-color: rgba(74, 111, 165, 0.1);
  color: var(--primary-dark);
  padding: 6px 16px;
  border-radius: 50px;
  font-size: 0.875rem;
  font-weight: 600;
  display: inline-block;
  margin-bottom: 24px;
}

.hero-text-area h1 {
  font-family: var(--font-hero);
  font-size: 3.5rem;
  line-height: 1.2;
  margin-bottom: 24px;
}

.hero-text-area h1 span {
  color: var(--primary);
  font-style: italic;
}

.hero-text-area p {
  color: var(--text-muted);
  font-size: 1.25rem;
  margin-bottom: 40px;
  max-width: 500px;
}

.hero-btns {
  display: flex;
  gap: 16px;
}

.gradient-text {
  background: linear-gradient(135deg, var(--primary), #a855f7);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  font-style: italic;
}

.decorative-blob-1 {
  position: absolute;
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(92, 124, 250, 0.1) 0%, transparent 70%);
  top: -100px;
  left: -200px;
  z-index: -1;
  filter: blur(50px);
}

.decorative-blob-2 {
  position: absolute;
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, rgba(230, 179, 37, 0.08) 0%, transparent 70%);
  bottom: -50px;
  right: -100px;
  z-index: -1;
  filter: blur(40px);
}

.hero-image-wrapper {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1.1;
  border-radius: 40px;
  overflow: visible; /* To allow floating tags to overflow slightly */
  box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.15);
  border: 4px solid white;
}

.floating-tag {
  position: absolute;
  background: white;
  padding: 12px 20px;
  border-radius: 50px;
  box-shadow: 0 10px 25px rgba(0,0,0,0.1);
  font-weight: 600;
  font-size: 0.9rem;
  z-index: 10;
  display: flex;
  align-items: center;
  gap: 8px;
  animation: float 4s ease-in-out infinite;
}

.tag-1 {
  top: 15%;
  left: -10%;
}

.tag-2 {
  bottom: 20%;
  right: -5%;
  animation-delay: 1s;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-15px); }
}

.hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  border-radius: 36px;
}

/* Stats Section */
.stats-bar {
  padding: 40px 0;
  background: white;
  margin-top: -60px;
  position: relative;
  z-index: 10;
  box-shadow: 0 10px 30px rgba(0,0,0,0.03);
  border-radius: 40px;
  margin-left: 24px;
  margin-right: 24px;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 40px;
  text-align: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.stat-number {
  font-size: 2.25rem;
  font-weight: 800;
  color: var(--primary-dark);
}

.stat-label {
  color: var(--text-muted);
  font-size: 0.875rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

@media (max-width: 768px) {
  .stats-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
}


/* Services */
.services {
  padding: var(--section-padding);
  background-color: #f8fafc;
}

.section-header {
  text-align: center;
  margin-bottom: 60px;
}

.section-header h2 {
  font-family: var(--font-hero);
  font-size: 2.5rem;
  margin-bottom: 16px;
}

.section-header p {
  color: var(--text-muted);
  font-size: 1.125rem;
  max-width: 600px;
  margin: 0 auto;
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 32px;
}

.service-card {
  background-color: var(--card-bg);
  backdrop-filter: blur(8px);
  padding: 48px 32px;
  border-radius: var(--border-radius);
  border: 1px solid var(--border-color);
  transition: var(--transition);
  text-align: center;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
}

.service-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    120deg,
    transparent,
    rgba(255, 255, 255, 0.3),
    transparent
  );
  transition: 0.6s;
}

.service-card:hover {
  transform: translateY(-12px) scale(1.02);
  box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
  border-color: var(--primary);
  background-color: #ffffff;
}

.service-card:hover::before {
  left: 100%;
}

.service-icon {
  font-size: 3.5rem;
  margin-bottom: 24px;
  filter: drop-shadow(0 10px 10px rgba(0,0,0,0.05));
  transition: transform 0.4s ease;
}

.service-card:hover .service-icon {
  transform: scale(1.1) rotate(5deg);
}

.price {
  font-weight: 700;
  color: var(--primary);
  font-size: 1.1rem;
}

/* Booking Section */
.booking-section {
  padding: var(--section-padding);
  background-color: white;
}

.booking-container {
  display: grid;
  grid-template-columns: 1fr 1.25fr;
  background-color: #f8fafc;
  border-radius: 24px;
  overflow: hidden;
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.05);
}

.booking-info {
  padding: 60px;
  background-color: var(--primary);
  color: white;
}

.booking-info h2 {
  font-family: var(--font-hero);
  font-size: 2rem;
  margin-bottom: 24px;
}

.booking-perks {
  list-style: none;
  margin-top: 32px;
}

.booking-perks li {
  margin-bottom: 16px;
  font-size: 1rem;
  display: flex;
  align-items: center;
  gap: 12px;
}

.booking-form-wrapper {
  padding: 60px;
  background-color: white;
}

.booking-form h3 {
  margin-bottom: 32px;
  font-size: 1.5rem;
}

.pet-type-selector {
  display: flex;
  gap: 16px;
  margin-bottom: 32px;
}

.pet-type-option {
  flex: 1;
  cursor: pointer;
}

.pet-type-option input {
  display: none;
}

.pet-card-ui {
  border: 2px solid var(--border-color);
  border-radius: var(--border-radius);
  padding: 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  transition: var(--transition);
}

.pet-type-option input:checked + .pet-card-ui {
  border-color: var(--primary);
  background-color: rgba(74, 111, 165, 0.05);
}

.pet-icon {
  font-size: 2rem;
}

.form-group {
  margin-bottom: 24px;
}

.form-group label {
  display: block;
  margin-bottom: 8px;
  font-weight: 500;
  color: var(--text-dark);
}

.form-group input, .form-group select {
  width: 100%;
  padding: 12px 16px;
  border: 1px solid var(--border-color);
  border-radius: var(--border-radius);
  font-family: inherit;
  font-size: 1rem;
  outline: none;
  transition: var(--transition);
}

.form-group input:focus, .form-group select:focus {
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgba(74, 111, 165, 0.1);
}

.form-step {
  display: none;
}

.form-step.active {
  display: block;
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

.form-actions {
  display: flex;
  gap: 16px;
  margin-top: 32px;
}

.full-width {
  width: 100%;
}

.success-message {
  text-align: center;
  padding: 40px 0;
}

.success-icon {
  font-size: 4rem;
  margin-bottom: 24px;
}

/* Footer */
.footer {
  background-color: #1a1a1a;
  color: white;
  padding: 60px 0 20px;
}

.footer-content {
  display: grid;
  grid-template-columns: 2fr 1fr;
  margin-bottom: 60px;
}

.footer-brand .logo {
  color: white;
  margin-bottom: 24px;
}

.footer-brand p {
  color: #999;
  max-width: 300px;
}

.footer-links {
  display: flex;
  gap: 60px;
}

.footer-links h4 {
  margin-bottom: 20px;
  font-size: 1.1rem;
}

.footer-links a {
  display: block;
  color: #999;
  text-decoration: none;
  margin-bottom: 12px;
  transition: var(--transition);
}

.footer-links a:hover {
  color: var(--primary);
}

/* Detail Section (Boarding) */
.detail-section {
  padding: var(--section-padding);
  background: white;
}

.split-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}

.detail-img {
  width: 100%;
  border-radius: 40px;
  box-shadow: 0 40px 80px -20px rgba(0,0,0,0.1);
}

.detail-content h2 {
  font-family: var(--font-hero);
  font-size: 3rem;
  margin: 20px 0;
}

.amenities-grid {
  margin-top: 40px;
  display: grid;
  gap: 30px;
}

.amenity {
  display: flex;
  gap: 20px;
  align-items: flex-start;
}

.amenity-icon {
  font-size: 1.5rem;
  background: rgba(92, 124, 250, 0.1);
  width: 50px;
  height: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12px;
}

.amenity h4 {
  margin-bottom: 4px;
}

.amenity p {
  color: var(--text-muted);
  font-size: 0.9rem;
}

/* About Section */
/* Adoption Section */
.adoption-section {
  padding: var(--section-padding);
  background: white;
}

.adoption-filters {
  display: flex;
  justify-content: center;
  gap: 15px;
  margin-bottom: 50px;
}

.filter-btn {
  padding: 10px 24px;
  border-radius: 30px;
  border: 1px solid var(--border);
  background: white;
  font-weight: 500;
  cursor: pointer;
  transition: 0.3s;
}

.filter-btn.active, .filter-btn:hover {
  background: var(--primary);
  color: white;
  border-color: var(--primary);
}

.pet-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 30px;
}

.pet-card {
  background: white;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  transition: 0.4s;
}

.pet-card:hover {
  transform: translateY(-10px);
  box-shadow: 0 20px 40px rgba(0,0,0,0.1);
}

.pet-img-wrap {
  position: relative;
  height: 240px;
}

.pet-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: crop;
}

.pet-status {
  position: absolute;
  top: 15px;
  right: 15px;
  background: #dcfce7;
  color: #166534;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 0.75rem;
  font-weight: 600;
}

.pet-info {
  padding: 24px;
}

.pet-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}

.pet-meta h3 {
  font-family: var(--font-hero);
  font-size: 1.5rem;
}

.pet-gender {
  font-size: 0.8rem;
  color: var(--text-muted);
}

.pet-breed {
  color: var(--text-muted);
  font-size: 0.9rem;
  margin-bottom: 20px;
}

.pet-tags {
  display: flex;
  gap: 8px;
  margin-bottom: 24px;
}

.pet-tags span {
  background: #f1f5f9;
  padding: 4px 10px;
  border-radius: 6px;
  font-size: 0.7rem;
  font-weight: 500;
}

.adopt-btn {
  width: 100%;
  padding: 12px;
  border-radius: 12px;
  background: var(--primary);
  color: white;
  border: none;
  font-weight: 600;
  cursor: pointer;
  transition: 0.3s;
}

.adopt-btn:hover {
  background: var(--primary-accent);
}

.about-section {
  padding: var(--section-padding);
  background: #f8fafc;
}

.about-card {
  background: white;
  padding: 80px;
  border-radius: 60px;
  box-shadow: 0 40px 100px -30px rgba(0,0,0,0.05);
}

.about-grid {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 60px;
  align-items: center;
}

.about-text h2 {
  font-family: var(--font-hero);
  font-size: 3.5rem;
  line-height: 1.1;
  margin-bottom: 30px;
}

.values {
  margin-top: 40px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.value-item {
  color: var(--text-dark);
  font-size: 1.1rem;
}

.about-visual {
  position: relative;
}

.staff-photo {
  width: 100%;
  border-radius: 40px;
  position: relative;
  z-index: 2;
}

.floating-circle {
  position: absolute;
  width: 300px;
  height: 300px;
  background: var(--primary);
  opacity: 0.1;
  border-radius: 50%;
  top: -40px;
  right: -40px;
}

@media (max-width: 968px) {
  .split-layout, .about-grid {
    grid-template-columns: 1fr;
    gap: 40px;
  }
}

.staff-link {
  margin-top: 16px;
  display: inline-block;
  opacity: 0.5;
  font-size: 0.75rem;
  border: 1px solid rgba(255,255,255,0.1);
  padding: 4px 8px;
  border-radius: 4px;
}

.staff-link:hover {
  opacity: 1;
  background: rgba(255,255,255,0.05);
}

.footer-bottom {
  border-top: 1px solid #333;
  padding-top: 20px;
  text-align: center;
  color: #666;
  font-size: 0.875rem;
}

/* Responsive */
@media (max-width: 968px) {
  .hero-content {
    grid-template-columns: 1fr;
    text-align: center;
  }
  
  .hero-text-area p {
    margin-left: auto;
    margin-right: auto;
  }
  
  .hero-btns {
    justify-content: center;
  }
  
  .booking-container {
    grid-template-columns: 1fr;
  }
  
  .booking-info {
    padding: 40px;
  }
  
  .nav-links {
    display: none;
  }
  
  .footer-content {
    grid-template-columns: 1fr;
    gap: 40px;
  }
}
