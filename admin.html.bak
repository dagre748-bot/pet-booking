<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PetPal Admin | Booking Management</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #5c7cfa;
            --bg: #f8fafc;
            --text: #1e293b;
            --white: #ffffff;
            --border: #e2e8f0;
        }
        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--bg);
            color: var(--text);
            margin: 0;
            display: flex;
        }
        .sidebar {
            width: 260px;
            height: 100vh;
            background: #1e293b;
            color: white;
            padding: 30px 20px;
            position: fixed;
        }
        .logo {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 40px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .nav-item {
            padding: 12px 15px;
            border-radius: 8px;
            margin-bottom: 10px;
            cursor: pointer;
            transition: 0.3s;
            display: flex;
            align-items: center;
            gap: 12px;
            background: rgba(255,255,255,0.05);
        }
        .nav-item.active {
            background: var(--primary);
        }
        .main-content {
            margin-left: 260px;
            flex: 1;
            padding: 40px;
        }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }
        .stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 40px;
        }
        .stat-card {
            background: white;
            padding: 24px;
            border-radius: 16px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        }
        .stat-val {
            font-size: 2rem;
            font-weight: 700;
            color: var(--primary);
        }
        .table-container {
            background: white;
            border-radius: 16px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
            overflow: hidden;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        th {
            text-align: left;
            padding: 16px 24px;
            background: #f1f5f9;
            font-weight: 600;
            font-size: 0.875rem;
            text-transform: uppercase;
            color: #64748b;
        }
        td {
            padding: 16px 24px;
            border-bottom: 1px solid var(--border);
        }
        .status-badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: capitalize;
        }
        .status-pending { background: #fef3c7; color: #92400e; }
        .status-completed { background: #dcfce7; color: #166534; }
        
        .btn-action {
            padding: 6px 12px;
            border-radius: 6px;
            border: 1px solid var(--border);
            background: white;
            cursor: pointer;
            font-size: 0.875rem;
        }
        .btn-delete {
            color: #ef4444;
        }
        .empty-state {
            padding: 60px;
            text-align: center;
            color: #94a3b8;
        }
    </style>
</head>
<body>
    <div id="login-overlay">
        <div class="login-card">
            <h2>🔐 Staff Login</h2>
            <p>Enter your credentials to access the PetPal dashboard.</p>
            <div id="login-error" style="color: #ef4444; margin-bottom: 15px; display: none; font-size: 0.85rem; font-weight: 600;">Invalid ID or Password</div>
            <div class="login-field">
                <label>Admin ID</label>
                <input type="text" id="admin-id" placeholder="ID-xxxx">
            </div>
            <div class="login-field" style="margin-top: 15px;">
                <label>Password</label>
                <input type="password" id="admin-pass" placeholder="••••••••">
            </div>
            <button class="login-btn" onclick="handleLogin()">Login to Dashboard</button>
            <a href="/" style="display: block; margin-top: 20px; color: #94a3b8; text-decoration: none; font-size: 0.8rem;">← Back to Home</a>
        </div>
    </div>

    <style>
        #login-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: #f1f5f9;
            z-index: 10000;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login-card {
            background: white;
            padding: 40px;
            border-radius: 24px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 400px;
            text-align: center;
        }
        .login-card h2 { margin-bottom: 8px; font-weight: 700; }
        .login-card p { color: #64748b; margin-bottom: 30px; font-size: 0.9rem; }
        .login-field { text-align: left; }
        .login-field label { display: block; margin-bottom: 6px; font-weight: 600; font-size: 0.85rem; }
        .login-field input {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            font-family: inherit;
        }
        .login-btn {
            width: 100%;
            padding: 14px;
            background: #5c7cfa;
            color: white;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            margin-top: 24px;
            cursor: pointer;
            transition: 0.3s;
        }
        .login-btn:hover { background: #364fc7; }
    </style>

    <script>
        // AUTH LOGIC
        function handleLogin() {
            const id = document.getElementById('admin-id').value;
            const pass = document.getElementById('admin-pass').value;
            const error = document.getElementById('login-error');

            if (id === 'Dipak' && pass === 'Dips@123') {
                document.getElementById('login-overlay').style.display = 'none';
                sessionStorage.setItem('isLoggedIn', 'true');
            } else {
                error.style.display = 'block';
                // Shake effect on error if you wanted, but keeping it simple
            }
        }

        // Check if already logged in for this session
        if (sessionStorage.getItem('isLoggedIn') === 'true') {
            document.getElementById('login-overlay').style.display = 'none';
        }

        // Dashboard Data Loading... (The original script continues below)
    </script>

    <div class="sidebar">
        <div class="logo">🐾 PetPal Admin</div>
        <div class="nav-item active" onclick="switchView('bookings')">📅 Bookings</div>
        <div class="nav-item" onclick="switchView('pets')">🐕 Pets</div>
        <div class="nav-item" onclick="switchView('adoptions')">🤝 Adoptions</div>
        <div class="nav-item" onclick="switchView('settings')">⚙️ Settings</div>
        <div style="margin-top: auto; padding-top: 40px;">
            <a href="/" style="color: #94a3b8; text-decoration: none; font-size: 0.875rem;">← Back to Website</a>
        </div>
    </div>

    <div class="main-content">
        <div id="bookings-view" class="view">
            <div class="header">
                <h1>Booking Management</h1>
                <button class="btn-action" onclick="refreshData()">🔄 Refresh</button>
            </div>
            <div class="stats">
                <div class="stat-card">
                    <div class="stat-label">Total Bookings</div>
                    <div class="stat-val" id="total-bookings">0</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Pending</div>
                    <div class="stat-val" id="pending-bookings">0</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Completed</div>
                    <div class="stat-val" id="completed-bookings">0</div>
                </div>
            </div>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Booking ID</th>
                            <th>Pet Name</th>
                            <th>Service</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="bookings-tbody"></tbody>
                </table>
                <div id="empty-msg" class="empty-state" style="display: none;">No bookings found.</div>
            </div>
        </div>

        <div id="pets-view" class="view" style="display: none;">
            <div class="header">
                <h1>Our Fluffy Clients (Pets)</h1>
            </div>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Pet Name</th>
                            <th>Type</th>
                            <th>Last Booking</th>
                            <th>History</th>
                        </tr>
                    </thead>
                    <tbody id="pets-tbody"></tbody>
                </table>
                <div id="empty-pets-msg" class="empty-state">No pets recorded yet.</div>
            </div>
        </div>

        <div id="adoptions-view" class="view" style="display: none;">
            <div class="header">
                <h1>Adoption Inquiries</h1>
            </div>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Interested Pet</th>
                            <th>Applicant</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="adoptions-tbody">
                        <tr>
                            <td>#AD-101</td>
                            <td>Buddy</td>
                            <td>Sample Applicant</td>
                            <td><span class="status-badge status-pending">In Review</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div id="settings-view" class="view" style="display: none;">
            <div class="header">
                <h1>System Settings</h1>
                <button class="btn-action" style="background: var(--primary); color: white;" onclick="alert('Settings Saved!')">Save Changes</button>
            </div>
            <div class="settings-form stat-card">
                <div class="form-group" style="margin-bottom: 20px;">
                    <label style="display: block; margin-bottom: 8px; font-weight: 600;">Site Name</label>
                    <input type="text" value="PetPal Care Services" style="width: 100%; padding: 10px; border: 1px solid var(--border); border-radius: 8px;">
                </div>
                <div class="form-group" style="margin-bottom: 20px;">
                    <label style="display: block; margin-bottom: 8px; font-weight: 600;">Contact Email</label>
                    <input type="email" value="admin@petpal.care" style="width: 100%; padding: 10px; border: 1px solid var(--border); border-radius: 8px;">
                </div>
                <div class="form-group" style="margin-bottom: 20px;">
                    <label style="display: block; margin-bottom: 8px; font-weight: 600;">System Language</label>
                    <select style="width: 100%; padding: 10px; border: 1px solid var(--border); border-radius: 8px;">
                        <option>English (US)</option>
                        <option>Spanish</option>
                    </select>
                </div>
                <hr style="margin: 30px 0; border: none; border-top: 1px solid var(--border);">
                <h4>Maintenance</h4>
                <button class="btn-action btn-delete" style="margin-top: 10px;" onclick="clearAllData()">⚠️ Clear All Data</button>
            </div>
        </div>
    </div>

    <script>
        function switchView(viewId) {
            document.querySelectorAll('.view').forEach(v => v.style.display = 'none');
            document.querySelectorAll('.nav-item').forEach(v => v.classList.remove('active'));
            
            document.getElementById(viewId + '-view').style.display = 'block';
            document.querySelector(`[onclick="switchView('${viewId}')"]`).classList.add('active');
            
            if (viewId === 'bookings') refreshData();
            if (viewId === 'pets') refreshPets();
        }

        function refreshPets() {
            const bookings = JSON.parse(localStorage.getItem('petpal_bookings') || '[]');
            const petsTbody = document.getElementById('pets-tbody');
            const emptyPetsMsg = document.getElementById('empty-pets-msg');
            
            petsTbody.innerHTML = '';
            
            if (bookings.length === 0) {
                emptyPetsMsg.style.display = 'block';
            } else {
                emptyPetsMsg.style.display = 'none';
                
                // Group by pet name to get a pet list
                const pets = {};
                bookings.forEach(b => {
                    if (!pets[b.petName]) {
                        pets[b.petName] = { name: b.petName, type: b.petType, count: 0, last: b.date };
                    }
                    pets[b.petName].count++;
                    if (new Date(b.date) > new Date(pets[b.petName].last)) pets[b.petName].last = b.date;
                });

                Object.values(pets).forEach(p => {
                    const row = document.createElement('tr');
                    row.innerHTML = `
                        <td><strong>${p.name}</strong></td>
                        <td>${p.type}</td>
                        <td>${new Date(p.last).toLocaleDateString()}</td>
                        <td>${p.count} Visited</td>
                    `;
                    petsTbody.appendChild(row);
                });
            }
        }

        function clearAllData() {
            if (confirm('Permanently delete all bookings and reset system?')) {
                localStorage.removeItem('petpal_bookings');
                location.reload();
            }
        }

        function refreshData() {
            const bookings = JSON.parse(localStorage.getItem('petpal_bookings') || '[]');
            const tbody = document.getElementById('bookings-tbody');
            const emptyMsg = document.getElementById('empty-msg');
            
            tbody.innerHTML = '';
            
            if (bookings.length === 0) {
                emptyMsg.style.display = 'block';
            } else {
                emptyMsg.style.display = 'none';
                
                // Sort by date (newest first)
                bookings.sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp));

                bookings.forEach((booking, index) => {
                    const row = document.createElement('tr');
                    row.innerHTML = `
                        <td style="font-weight: 500;">${booking.id}</td>
                        <td>${booking.petName} <span style="opacity: 0.5; font-size: 0.8rem;">(${booking.petType})</span></td>
                        <td>${booking.service}</td>
                        <td>${new Date(booking.date).toLocaleDateString()}</td>
                        <td><span class="status-badge status-${booking.status}">${booking.status}</span></td>
                        <td>
                            <button class="btn-action" onclick="toggleStatus('${booking.id}')">Toggle Status</button>
                            <button class="btn-action btn-delete" onclick="deleteBooking('${booking.id}')">Delete</button>
                        </td>
                    `;
                    tbody.appendChild(row);
                });
            }

            // Stats
            document.getElementById('total-bookings').textContent = bookings.length;
            document.getElementById('pending-bookings').textContent = bookings.filter(b => b.status === 'pending').length;
            document.getElementById('completed-bookings').textContent = bookings.filter(b => b.status === 'completed').length;
        }

        function toggleStatus(id) {
            let bookings = JSON.parse(localStorage.getItem('petpal_bookings') || '[]');
            bookings = bookings.map(b => {
                if (b.id === id) {
                    b.status = b.status === 'pending' ? 'completed' : 'pending';
                }
                return b;
            });
            localStorage.setItem('petpal_bookings', JSON.stringify(bookings));
            refreshData();
        }

        function deleteBooking(id) {
            if (confirm('Are you sure you want to delete this booking?')) {
                let bookings = JSON.parse(localStorage.getItem('petpal_bookings') || '[]');
                bookings = bookings.filter(b => b.id !== id);
                localStorage.setItem('petpal_bookings', JSON.stringify(bookings));
                refreshData();
            }
        }

        // Initial load
        window.onload = refreshData;
    </script>
</body>
</html>
